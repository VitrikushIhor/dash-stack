# ============================================
# DATABASE
# ============================================
POSTGRES_USER=prisma
POSTGRES_PASSWORD=topsecret
POSTGRES_DB=blog
DB_SCHEMA=blog

# ============================================
# BACKEND
# ============================================
BACKEND_PORT=8000

# CORS (comma-separated list of allowed origins)
# For development: http://localhost:3000
# For production: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:3000

# JWT
JWT_ACCESS_SECRET=nestjsPrismaAccessSecret
JWT_REFRESH_SECRET=nestjsPrismaRefreshSecret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Logs
ENABLE_LOGS=false

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=test@gmail.com
SMTP_PASS=testpass
FRONTEND_URL=http://localhost:3000


# ============================================
# FRONTEND
# ============================================
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8000

# 0auth 
VITE_AUTH0_DOMAIN=test
VITE_AUTH0_CLIENT_ID=test




# BACKEND
# ============================================
# Storage (S3 + CloudFront)
# ============================================

# Provider: 's3' (production) or 'local' (development without AWS)
STORAGE_PROVIDER=s3

# AWS S3 Configuration
AWS_S3_BUCKET=your-bucket-name
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# CloudFront CDN domain (without https://)
# Example: d1234abcdef.cloudfront.net
AWS_CLOUDFRONT_DOMAIN=your-distribution-id.cloudfront.net