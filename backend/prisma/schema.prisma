generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// AUTH MODELS
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String? // null якщо OAuth-only користувач
  emailVerified DateTime?
  firstName     String?
  lastName      String?
  avatar        String?

  // OAuth providers
  accounts      Account[]
  refreshTokens RefreshToken[]

  // App relations
  memberships Membership[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  provider          String // "google", "github", "credentials"
  providerAccountId String
  accessToken       String? @db.Text
  refreshToken      String? @db.Text
  expiresAt         Int?
  tokenType         String?
  scope             String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model VerificationToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  type      TokenType
  expires   DateTime
  createdAt DateTime  @default(now())

  @@unique([email, token])
  @@index([email])
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  userAgent String? // browser/device info
  ipAddress String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ============================================
// ORGANIZATION & MEMBERSHIP
// ============================================

model Organization {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  logo        String?
  stripeId    String? // для payments

  memberships    Membership[]
  tasks          Task[]
  projects       Project[]
  calendarEvents CalendarEvent[]
  invitations    Invitation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Membership {
  id       String        @id @default(cuid())
  userId   String
  orgId    String
  role     OrgRole       @default(MEMBER)
  position TeamPosition?
  joinedAt DateTime      @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tasks        Task[]       @relation("TaskAssignees")

  @@unique([userId, orgId])
  @@index([userId])
  @@index([orgId])
}

model Invitation {
  id         String    @id @default(cuid())
  email      String
  orgId      String
  role       OrgRole   @default(MEMBER)
  token      String    @unique @default(cuid())
  expiresAt  DateTime
  invitedBy  String
  acceptedAt DateTime?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([email])
  @@index([orgId])
  @@index([token])
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum TeamPosition {
  PRODUCT_MANAGER
  LEAD_DEVELOPER
  FRONTEND_DEVELOPER
  BACKEND_DEVELOPER
  UI_UX_DESIGNER
  QA_ENGINEER
  DEVOPS_ENGINEER
}

// ============================================
// PROJECTS & TASKS
// ============================================

model Project {
  id          String  @id @default(cuid())
  orgId       String
  name        String
  description String?
  color       String? // для UI (hex колір)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
}

enum TaskStatus {
  PLANNED
  UPCOMING
  COMPLETED
}

model Task {
  id             String     @id @default(cuid())
  title          String
  description    String?
  status         TaskStatus @default(PLANNED)
  deadline       DateTime?
  attachments    String[]   @default([])
  organizationId String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignees      Membership[]    @relation("TaskAssignees")
  labels         TaskLabel[]
  checklists     Checklist[]
  calendarEvents CalendarEvent[]

  @@unique([id, organizationId])
  @@index([organizationId])
  @@index([organizationId, status])
  @@map("tasks")
}

model TaskLabel {
  id     String @id @default(cuid())
  name   String
  color  String
  taskId String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_labels")
}

model Checklist {
  id     String @id @default(cuid())
  name   String
  taskId String

  task  Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  items ChecklistItem[]

  @@index([taskId])
  @@map("checklists")
}

model ChecklistItem {
  id          String  @id @default(cuid())
  title       String
  completed   Boolean @default(false)
  checklistId String

  checklist Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId])
  @@map("checklist_items")
}

// ============================================
// CALENDAR
// ============================================

model CalendarEvent {
  id     String    @id @default(cuid())
  orgId  String
  taskId String?
  title  String
  start  DateTime
  end    DateTime?
  type   EventType @default(TASK)

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  task         Task?        @relation(fields: [taskId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([start])
}

enum EventType {
  TASK
  MEETING
  DEADLINE
  REMINDER
}
